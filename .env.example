# ============================================
# Swap Platform - 环境变量模板
# 复制为 .env 并填入真实值，切勿提交到代码仓库
# ============================================

# MySQL 数据库配置
MYSQL_DATABASE=swap-platform
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# Knife4j 文档基础认证（可选，生产环境建议开启）
KNIFE4J_USER=admin
KNIFE4J_PASSWORD=admin123
